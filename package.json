{
  "type": "module",
  "private": "true",
  "version": "0.0.0",
  "main": "public/index.js",
  "scripts": {
    "lint": "eslint \"./**/*.{ts,js}\"",
    "build-tests": "esbuild test/index.ts --bundle --format=cjs --keep-names > test/test-bundle.js",
    "test": "npm run lint && npm run build && npm run build-tests && npm run test-tape-run",
    "test-tape-run": "cat test/index.html | npx tape-run --input=html --static=test | npx tap-spec",
    "build": "mkdir -p ./public && rm -rf ./public/* && vite build",
    "start": "concurrently --kill-others \"npx ntl functions:serve --port=9999 --debug\" \"npx vite\"",
    "preversion": "npm run lint",
    "version": "auto-changelog --template keepachangelog --breaking-pattern 'BREAKING CHANGE' && git add CHANGELOG.md",
    "postversion": "git push --follow-tags",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@atproto/api": "^0.18.17",
    "@atproto/identity": "^0.4.10",
    "@preact/signals": "^2.6.1",
    "@substrate-system/a11y": "^0.0.17",
    "@substrate-system/atrament": "^5.1.4",
    "@substrate-system/css-normalize": "^0.0.13",
    "@substrate-system/meta-tags": "^0.0.5",
    "@substrate-system/routes": "^5.0.5",
    "htm": "^3.1.1",
    "ky": "^1.14.3",
    "preact": "^10.28.2",
    "route-event": "^7.4.0"
  },
  "devDependencies": {
    "@netlify/functions": "^5.1.2",
    "@preact/preset-vite": "^2.9.4",
    "@substrate-system/debug": "^0.9.54",
    "@substrate-system/tapzero": "^0.10.15",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.8.1",
    "auto-changelog": "^2.4.0",
    "browserslist": "^4.28.1",
    "concurrently": "^9.0.1",
    "esbuild": "^0.27.2",
    "eslint": "^8.57.0",
    "eslint-config-standard": "^17.1.0",
    "lightningcss": "^1.31.1",
    "netlify-cli": "^23.13.5",
    "stylelint": "^17.0.0",
    "stylelint-config-standard": "^40.0.0",
    "tap-spec": "^5.0.0",
    "tape-run": "^11.0.0",
    "typescript": "^5.8.2",
    "vite": "^7.3.1"
  },
  "author": "nichoth <nichoth@nichoth.com> (https://nichoth.com)"
}
