{
  "type": "module",
  "private": "true",
  "version": "0.0.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "main": "public/index.js",
  "scripts": {
    "lint": "eslint \"./**/*.{ts,js}\"",
    "build-tests": "esbuild test/index.ts --bundle --format=cjs --keep-names > test/test-bundle.js",
    "test:e2e": "vitest run",
    "test:watch": "vitest",
    "test": "esbuild ./test/index.ts --bundle | tapout",
    "build": "mkdir -p ./public && rm -rf ./public/* && vite build && cp _public/* public",
    "build:staging": "mkdir -p ./public && rm -rf ./public/* && vite build --mode=\"staging\" && cp _public/* public",
    "start": "concurrently --kill-others \"npx ntl functions:serve --port=9999 --debug\" \"npx vite\"",
    "preversion": "npm run lint",
    "version": "auto-changelog --template keepachangelog --breaking-pattern 'BREAKING CHANGE' && git add CHANGELOG.md",
    "postversion": "git push --follow-tags",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@atproto/api": "^0.18.8",
    "@atproto/identity": "^0.4.10",
    "@atproto/oauth-client": "^0.6.0",
    "@atproto/oauth-client-browser": "^0.3.41",
    "@atproto/oauth-client-node": "^0.3.17",
    "@preact/signals": "^2.0.1",
    "@simplewebauthn/browser": "^13.2.2",
    "@substrate-system/a11y": "^0.0.17",
    "@substrate-system/atrament": "^5.1.4",
    "@substrate-system/character-counter": "^0.0.4",
    "@substrate-system/css-normalize": "^0.0.13",
    "@substrate-system/dialog": "^0.0.28",
    "@substrate-system/input": "^0.0.21",
    "@substrate-system/meta-tags": "^0.0.2",
    "@substrate-system/password-input": "^0.0.4",
    "@substrate-system/routes": "^5.0.2",
    "@substrate-system/state": "^0.0.8",
    "htm": "^3.1.1",
    "ky": "^1.14.1",
    "preact": "^10.28.0",
    "route-event": "^7.4.0"
  },
  "devDependencies": {
    "@netlify/functions": "^4.1.8",
    "@preact/preset-vite": "^2.9.4",
    "@substrate-system/debug": "^0.9.0",
    "@substrate-system/tapout": "^0.0.35",
    "@substrate-system/tapzero": "^0.10.15",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/preact": "^3.2.4",
    "@testing-library/user-event": "^14.6.1",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "auto-changelog": "^2.4.0",
    "browserslist": "^4.28.1",
    "concurrently": "^9.0.1",
    "esbuild": "^0.25.0",
    "eslint": "^8.57.0",
    "eslint-config-standard": "^17.1.0",
    "jsdom": "^28.1.0",
    "lightningcss": "^1.30.2",
    "netlify-cli": "^23.4.3",
    "stylelint": "^16.13.0",
    "stylelint-config-standard": "^39.0.0",
    "tap-spec": "^5.0.0",
    "typescript": "^5.8.2",
    "vite": "^7.0.0",
    "vitest": "^4.0.18"
  },
  "author": "nichoth <nichoth@nichoth.com> (https://nichoth.com)"
}
